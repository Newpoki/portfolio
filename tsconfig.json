{
  "compilerOptions": {
    "jsx": "react-jsx",
    "moduleResolution": "Bundler",
    "module": "ESNext",
    "target": "ES2022",
    "skipLibCheck": true,
    "strictNullChecks": true,
    "verbatimModuleSyntax": false,
    "noUncheckedIndexedAccess": true,
    "allowJs": true, // Needed for paraglide i18n
    "paths": {
      "@/*": ["./src/*"]
    },
    "outDir": "./dist",
    "strict": true
  },
  "include": ["**/*.ts", "**/*.tsx"]
}
